# Copy to `.env` for local development. Do not commit `.env`.
# Vite only exposes variables prefixed with VITE_ to the browser.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend API base URL (required for production builds on Vercel so /api/* calls reach Azure, not the static site).
# Local: http://localhost:5250  |  Production: https://YOUR-APP.azurewebsites.net
VITE_API_BASE_URL=

# Google reCAPTCHA v2 site key (public; safe to expose in the client bundle)
VITE_RECAPTCHA_SITE_KEY=
